            "name": "count by severity - Column chart search",
            "options": {
                "query": "index=main source=Sample_tickets.csv current_ticket_state=\"$ticket_state$\" \n| stats count by severity",
                "queryParameters": {
                    "earliest": "$time_token.earliest$",
                    "latest": "$time_token.latest$",
                    "sampleRatio": 1
                }
            },
            "type": "ds.search"
        },
        "ds_t0AffhvR": {
            "name": "Search_1",
            "options": {
                "extend": "ds_KIekZpLw",
