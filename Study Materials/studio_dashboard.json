        },
        "ds_yc2YpmAo": {
            "name": "Count by ticket state search",
            "options": {
                "query": "index=main source=Sample_tickets.csv | stats count BY current_ticket_state",
                "queryParameters": {
                    "earliest": "$time_token.earliest$",
                    "latest": "$time_token.latest$",
                    "sampleRatio": 1
                }
            },
            "type": "ds.search"
        }
